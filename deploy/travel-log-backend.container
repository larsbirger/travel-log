[Unit]
Description=Travel log backend
After=travel-log-pod.service travel-log-postgres-container.service travel-log-network.service travel-log-volume.service
Requires=travel-log-pod.service travel-log-postgres-container.service travel-log-network.service travel-log-volume.service

[Container]

Image=travel-log-backend

Exec=npm run dev
EnvironmentFile=/etc/containers/app.env

Volume=postgres-socket:/run/postgres
Pod=travel-log.pod




    