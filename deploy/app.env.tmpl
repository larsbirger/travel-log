# ==============================================================================
# ENVIRONMENT CONFIGURATION BLUEPRINT
# ==============================================================================
# Copy this file to /etc/containers/app.env and populate with production values.
# Do not commit real passwords or secret tokens to version control.

# --- Infrastructure / Network ---
APP_ENV=production
PORT=8080
HOST_IP=127.0.0.1

# --- Security & Cryptography ---
# Generate a secure string (e.g., via 'openssl rand -hex 32')
API_SECRET_KEY=CHANGE_THIS_TO_A_LONG_SECURE_RANDOM_HEX_STRING

# --- Database Configurations (If applicable) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=system_user
DB_PASSWORD=CHOOSE_A_SECURE_DATABASE_PASSWORD_HERE
DB_NAME=application_db

# --- Cross-Origin Resource Sharing (CORS) ---
# Crucial later for your multi-platform mobile API calls
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1